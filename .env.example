# Optional — only used to pre-fill the in-app Setup screen the first time
# the container starts. After you save in the web UI, /data/config.json
# wins, so you can clear these.

IMMICH_URL=
IMMICH_API_KEY=

# Override the listen port if 5000 is taken on the host.
# PORT=5000
# HOST=0.0.0.0

# ─── Disk cache (all optional) ────────────────────────────────────────
# CACHE_ENABLED=true                          # set to false to disable
# CACHE_DIR=/data/cache                       # where to store cache files
# CACHE_MAX_AGE_SECONDS=86400                 # evict entries older than this (24h)
# CACHE_MAX_BYTES=2147483648                  # evict oldest when total > this (2 GB)
# CACHE_MAX_FILE_BYTES=209715200              # don't cache individual files > this (200 MB)
# CACHE_CLEANUP_INTERVAL_SECONDS=600          # how often the cleaner runs
